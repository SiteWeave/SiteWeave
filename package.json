{
  "name": "siteweave",
  "private": true,
  "version": "1.0.70",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite --config vite.config.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "build:win": "vite build --config vite.config.mjs && electron-builder --win --publish never",
    "build:mac": "vite build --config vite.config.mjs && electron-builder --mac --publish never",
    "build:win:appx": "vite build --config vite.config.mjs && electron-builder --win --config.win.target=appx --publish never",
    "build:win:msix": "npm run build:win:appx",
    "sync:progress-report-templates": "node scripts/sync-progress-report-templates.mjs",
    "verify:progress-report-sync": "node scripts/verify-progress-report-sync.mjs",
    "test:progress-report-stability": "node scripts/test-progress-report-stability.mjs",
    "regen:win-update-meta": "node scripts/regen-win-update-metadata.mjs"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@supabase/supabase-js": "^2.103.0",
    "electron-updater": "^6.8.3",
    "exifr": "^7.1.3",
    "frappe-gantt": "^1.2.1",
    "html2canvas": "^1.4.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "jspdf": "^4.2.1",
    "libphonenumber-js": "^1.12.42",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.3",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.47",
    "supabase": "^2.89.0",
    "tailwindcss": "^4.2.0",
    "terser": "^5.44.1",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
